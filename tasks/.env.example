# Whiskey & Smokes — Local Docker Deployment
# Copy to .env and fill in your values
# Populate from Terraform outputs: task local:output

# Required: JWT signing secret (minimum 32 characters)
JWT_SECRET=change-this-to-a-long-random-string-min-32-chars

# Required: Azure AI Foundry project endpoint
# From: terraform -chdir=infrastructure/local output FOUNDRY_PROJECT_ENDPOINT
AI_FOUNDRY_PROJECT_ENDPOINT=

# Required: Service principal for Foundry authentication
# From: terraform -chdir=infrastructure/local output SPN_CLIENT_ID
#       terraform -chdir=infrastructure/local output SPN_TENANT_ID
#       terraform -chdir=infrastructure/local output -raw SPN_CLIENT_SECRET
AZURE_CLIENT_ID=
AZURE_TENANT_ID=
AZURE_CLIENT_SECRET=

# Optional: Port for the web UI (default: 8080)
# WEB_PORT=8080

# Optional: Canonical browser-facing origin for OIDC redirects
# OIDC_PUBLIC_ORIGIN=http://localhost:8080

# Optional: Entra ID authentication (leave blank for local-only auth)
# ENTRA_TENANT_ID=
# ENTRA_CLIENT_ID=
# Optional: Accepted token audience (defaults to ENTRA_CLIENT_ID)
# ENTRA_AUDIENCE=
